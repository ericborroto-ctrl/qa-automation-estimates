# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is gitignored - it should never be committed.
#
# To add a user:
#   1. Run: python tools/generate_password_hash.py
#   2. Paste the resulting hash below as that user's "password" value
#      (never paste the plaintext password here)
#
# On Streamlit Cloud, instead of a file, paste this same content into
# your app's Settings -> Secrets box in the dashboard.

[auth]
cookie_name = "qa_automation_auth"
cookie_key = "replace-with-a-long-random-string"   # any random string, used to sign the login cookie
cookie_expiry_days = 30

[auth.credentials.usernames.jsmith]
name = "Jane Smith"
email = "jane.smith@pauldavis.com"
password = "$2b$12$REPLACE_WITH_GENERATED_HASH"

[auth.credentials.usernames.eborroto]
name = "Eric Borroto"
email = "eric.borroto@pauldavis.com"
password = "$2b$12$REPLACE_WITH_GENERATED_HASH"
